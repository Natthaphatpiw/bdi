{
  "name": "rusit-rusuk",
  "version": "0.1.0",
  "private": true,
  "description": "รู้สิทธิ์ รู้สุข — Verified Rights-to-Care Navigation for Web and LINE LIFF",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "npm run validate:knowledge && next build",
    "start": "next start",
    "lint": "eslint app components hooks lib store scripts tests --ext .ts,.tsx --no-error-on-unmatched-pattern",
    "typecheck": "tsc --noEmit",
    "validate:knowledge": "tsx scripts/validate-knowledge-data.ts",
    "test": "npm run validate:knowledge && vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@ai-sdk/google": "^4.0.3",
    "@anthropic-ai/sdk": "^0.110.0",
    "@google/genai": "^2.10.0",
    "@line/liff": "^2.25.1",
    "@mastra/core": "^1.47.0",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@supabase/supabase-js": "^2.47.10",
    "@tanstack/react-query": "^5.62.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.468.0",
    "next": "^15.1.3",
    "pdf-parse": "^1.1.1",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.2",
    "@types/pdf-parse": "^1.1.4",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.19",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.23.1",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}

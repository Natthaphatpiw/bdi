# =============================================================================
# รู้สิทธิ์ รู้สุข — environment (copy to .env.local and fill in)
# Public (NEXT_PUBLIC_*) values are exposed to the browser. Everything else is
# server-only and must NEVER be prefixed NEXT_PUBLIC_.
# =============================================================================

# --- Supabase (SQL + pgvector + Auth + Storage) ---------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# anon/public key — Project Settings → API → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role key — server only (bypasses RLS). Project Settings → API.
SUPABASE_SERVICE_KEY=

# --- Claude (primary text LLM: NLU / คำถามคัดกรอง / synthesis / passport agent) --
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-5

# --- Google Gemini (STT + embeddings; text fallback when Claude unavailable) -----
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
EMBED_MODEL=gemini-embedding-001
EMBED_DIM=768

# --- ThaiLLM-27B-Prescreen on RunPod Serverless (OpenAI-compatible route) --------
RUNPOD_ENDPOINT_ID=
RUNPOD_API_KEY=
RUNPOD_PRESCREEN_ADAPTER=prescreen
# Max wait (ms) for the 27B before falling back to Gemini triage + rails (keeps
# /api/turn under the serverless limit on a cold worker). Keep RunPod warm to avoid this.
RUNPOD_TIMEOUT_MS=20000

# --- Neo4j Aura (Civic Knowledge Graph) -----------------------------------------
NEO4J_URI=neo4j+s://XXXX.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# --- LINE LIFF (one app per page; set each app's Endpoint URL in LINE console) ---
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
NEXT_PUBLIC_LIFF_ID_HOME=          # Endpoint: https://<domain>/liff
NEXT_PUBLIC_LIFF_ID_CHAT=          # Endpoint: https://<domain>/liff/chat
NEXT_PUBLIC_LIFF_ID_RIGHTS=        # Endpoint: https://<domain>/liff/rights
NEXT_PUBLIC_LIFF_ID_FACILITIES=    # Endpoint: https://<domain>/liff/facilities
NEXT_PUBLIC_LIFF_ID_DOCUMENTS=     # Endpoint: https://<domain>/liff/documents
NEXT_PUBLIC_LIFF_ID_PROFILE=       # Endpoint: https://<domain>/liff/profile
NEXT_PUBLIC_LIFF_ID_HISTORY=       # Endpoint: https://<domain>/liff/history
NEXT_PUBLIC_LIFF_ID=               # legacy single-id fallback (optional)

# --- App ------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=รู้สิทธิ์ รู้สุข
# Admin allow-list for /api/admin/* (comma-separated Supabase user ids). Empty = no admin access.
ADMIN_USER_IDS=

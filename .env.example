# รู้สิทธิ์ รู้สุข — MVP runtime configuration
# Copy to .env.local. Never commit real secrets.

# Active providers (booth/production MVP)
MODEL_PROVIDER=claude
KNOWLEDGE_PROVIDER=supabase
ENABLE_JSON_KNOWLEDGE_FALLBACK=true

# Booth and product flags
DEMO_MODE=true
ENABLE_PRIVATE_OPTIONS=false
ENABLE_FACILITY_FEEDBACK=true
ENABLE_PASSPORT_SHARE=true
ADMIN_DEBUG=false

# Supabase — public values may be exposed to the browser; service role is server-only.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Claude — server-only. Each structured call has a total 12-second budget and at most one repair/retry.
CLAUDE_API_KEY=
# ANTHROPIC_API_KEY= may be used instead of CLAUDE_API_KEY.
CLAUDE_MODEL=claude-sonnet-5

# Optional legacy media helpers only (not used for text reasoning in the MVP).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
EMBED_MODEL=gemini-embedding-001
EMBED_DIM=768
LEGACY_ENABLE_GEMINI_TEXT_FALLBACK=false

# LINE LIFF — one app per entry route, all under the same LINE Login channel.
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
NEXT_PUBLIC_LIFF_ID_HOME=
NEXT_PUBLIC_LIFF_ID_CHAT=
NEXT_PUBLIC_LIFF_ID_RIGHTS=
NEXT_PUBLIC_LIFF_ID_FACILITIES=
NEXT_PUBLIC_LIFF_ID_DOCUMENTS=
NEXT_PUBLIC_LIFF_ID_PROFILE=
NEXT_PUBLIC_LIFF_ID_HISTORY=
NEXT_PUBLIC_LIFF_ID=

# Admin allow-list for existing admin APIs (comma-separated Supabase user UUIDs).
ADMIN_USER_IDS=
NEXT_PUBLIC_APP_NAME=รู้สิทธิ์ รู้สุข

# Future adapters — documented but not required and never called by default.
# MODEL_PROVIDER=thaillm
# THAILLM_BASE_URL=
# THAILLM_API_KEY=
# KNOWLEDGE_PROVIDER=neo4j
# NEO4J_URI=
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=
# NEO4J_DATABASE=neo4j
